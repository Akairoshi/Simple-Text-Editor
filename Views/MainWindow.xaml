<Window x:Class="Simple_Text_Editor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Simple_Text_Editor"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:infra="clr-namespace:Simple_Text_Editor.Infrastructure"
        mc:Ignorable="d"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver"
        MinWidth="400" MinHeight="200" Closing="Window_Closing"
        Title="{Binding Title}" Height="450" Width="800" Icon="/Assets/Icons/AppIcon.png">
    
    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Control"
        Command="{Binding SaveCommand}" />

        <KeyBinding 
        Key="S" Modifiers="Control+Shift"
        Command="{Binding SaveAsCommand}" />

        <KeyBinding 
        Key="O" Modifiers="Control"
        Command="{Binding OpenFileCommand}" />

        <KeyBinding 
        Key="N" Modifiers="Control"
        Command="{Binding NewFileCommand}" />

        <KeyBinding Key="OemPlus" Modifiers="Control+Shift"
        Command="{Binding ChangeFontSizeCommand}" CommandParameter="=" />

        <KeyBinding Key="OemPlus" Modifiers="Control"
        Command="{Binding ChangeFontSizeCommand}" CommandParameter="+" />

        <KeyBinding Key="OemMinus" Modifiers="Control"
        Command="{Binding ChangeFontSizeCommand}" CommandParameter="-" />

        <KeyBinding Key="M" Modifiers="Control+Shift"
        Command="{Binding TogglePreviewCommand}"/>
        
    </Window.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="23.04"/>
        </Grid.RowDefinitions>
        
        <!-- Верхний док -->
        <Border BorderBrush="#FF969696" BorderThickness="0,0,0,1" Margin="15,0,15,0">
            <StackPanel Orientation="Horizontal" Margin="0,0,-2,0">
                
                <Menu VerticalAlignment="Stretch">
                    
                    <!-- Меню с файлами -->
                    <MenuItem Header="File">
                        <MenuItem Header="Open file" Command="{Binding OpenFileCommand}"
                              InputGestureText="{x:Static local:Hotkeys.Open}"/>
                        <MenuItem Header="Save file">
                            <MenuItem Header="Save.." Command="{Binding SaveCommand}"
                                  InputGestureText="{x:Static local:Hotkeys.Save}"/>
                            <MenuItem Header="Save as.." Command="{Binding SaveAsCommand}"
                            InputGestureText="{x:Static local:Hotkeys.SaveAs}"/>
                        </MenuItem>
                        <MenuItem Header="New file" Command="{Binding NewFileCommand}"
                              InputGestureText="{x:Static local:Hotkeys.NewFile}"/>
                        <MenuItem Header="Add to Open With"
                              Command="{Binding RegisterOpenWithCommand}" />
                        <Separator/>
                        <MenuItem Header="Exit" Command="{Binding ExitCommand}"
                              InputGestureText="{x:Static local:Hotkeys.Exit}"/>
                    </MenuItem>
                    
                    <!-- Меню с настройкой вида -->
                    <MenuItem Header="View">
                        <MenuItem Header="Font Size">
                            <MenuItem Header="Add size" Command="{Binding ChangeFontSizeCommand}" CommandParameter="+"
                                  InputGestureText="{x:Static local:Hotkeys.AddSize}"/>
                            <MenuItem Header="Subtract size" Command="{Binding ChangeFontSizeCommand}" CommandParameter="-"
                                  InputGestureText="{x:Static local:Hotkeys.SubSize}"/>
                            <MenuItem Header="Set default size" Command="{Binding ChangeFontSizeCommand}" CommandParameter="="
                                  InputGestureText="{x:Static local:Hotkeys.ResetSize}"/>
                        </MenuItem>
                        <MenuItem Header="Show dock" IsChecked = "{Binding DockIsVisible}"
                                  Command="{Binding ToggleDockCommand}"/>
                        <MenuItem Header="Show preview" IsChecked="{Binding IsPreviewVisible}"
                                  Command="{Binding TogglePreviewCommand}"
                                  InputGestureText="{x:Static local:Hotkeys.ToggleMdPreview}"/>
                    </MenuItem>
                    
                    <!-- Меню о программе -->
                    <MenuItem Header="About" Command="{Binding OpenAboutCommand}"/>
                </Menu>
            </StackPanel>
        </Border>
        
        <!-- Нижний док с информацией -->
        <DockPanel Visibility="{Binding DockVisibility}" Grid.Row="2">

            <!-- Левая часть -->
            <StackPanel Orientation="Horizontal" Width="100" HorizontalAlignment="Left">
                <Border BorderBrush="#FF969696" Width="100" BorderThickness="0,0,1,0" UseLayoutRounding="True" Height="20" VerticalAlignment="Center">
                    <TextBlock  TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" Width="92" Text="{Binding CaretStatus}"/>
                </Border>
            </StackPanel>

            <!-- Правая часть -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Border BorderBrush="#FF969696" BorderThickness="1,0,0,0" Width="100">
                    <TextBlock TextWrapping="Wrap" Text="{Binding FontSizeStatus}" HorizontalAlignment="Left" Width="92" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </Border>
                <Border BorderBrush="#FF969696" BorderThickness="1,0,0,0" Width="200">
                    <TextBlock TextWrapping="Wrap" Text="{Binding CurrentEncoding}" HorizontalAlignment="Left" Width="189" Height="18" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </Border>
            </StackPanel>
            
        </DockPanel>

        <!-- Поле редактора -->
        <Grid Grid.Row="1" Margin="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="{Binding SplitterWidth}"/>
                <ColumnDefinition Width="{Binding RightPaneWidth}"/>
            </Grid.ColumnDefinitions>

            <!-- Поле AvalonEdit -->
            <avalonedit:TextEditor Grid.Column="0"
                 x:Name="Editor"
                 Loaded="Editor_Loaded"
                 Unloaded="Editor_Unloaded"
                 PreviewMouseWheel="Window_MouseWheel"
                 ShowLineNumbers="True"
                 FontFamily="Consolas"
                 FontSize="{Binding EditorFontSize}"
                 HorizontalScrollBarVisibility="Auto"
                 VerticalScrollBarVisibility="Auto"
                 infra:AvalonEditBinding.Text="{Binding EditorText}"
                 BorderBrush="Black"
                 Background="{x:Null}"/>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                 Visibility="{Binding RightPaneVisibility}"/>

            <!-- WebView предпросмотр MarkDown -->
            <Border Grid.Column="2"
                    BorderBrush="#FF969696"
                    BorderThickness="1,0,0,0"
                    Visibility="{Binding RightPaneVisibility}">

                <wv2:WebView2 local:WebView2HtmlBehavior.Html="{Binding PreviewHtml}" />

            </Border>
            
        </Grid>
        
    </Grid>
    
</Window>
